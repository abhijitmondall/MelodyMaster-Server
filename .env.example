# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/melodymasters?schema=public"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Access Token ─────────────────────────────────────────────────────────────
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_EXPIRES_IN=15m

# ─── Refresh Token ────────────────────────────────────────────────────────────
JWT_REFRESH_SECRET=your-refresh-token-secret-different-from-above
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_MS=604800000

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
PAYMENT_SECRET_KEY=sk_test_...

# Get this by running: stripe listen --forward-to localhost:5000/api/v1/payment/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Used for Stripe success_url / cancel_url redirects
FRONTEND_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
